# Required everywhere
ANTHROPIC_API_KEY=sk-ant-...

# Local-only (Gmail MCP). Hosted Vercel deploy uses fixtures.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# Toggle email source: "fixtures" (default, hosted-safe) or "gmail-mcp" (local only)
EMAIL_SOURCE=fixtures

# Google OAuth for sign-in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# 32+ random bytes, base64 or hex. Used to sign session cookies.
AUTH_SECRET=
